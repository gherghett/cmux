#!/usr/bin/env bash
# cmux claude wrapper — injects hooks for status/notification integration.
# Only active inside cmux (CMUX_SURFACE_ID is set). Outside cmux, passes through.
#
# Hooks:
#   UserPromptSubmit → ✦ Running (Claude is working on a prompt)
#   Stop             → ● Unread (Claude finished, show last message)
#   Notification     → ● Attention (Claude needs permission)

find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through if not in cmux or hooks disabled
if [[ -z "$CMUX_SURFACE_ID" || "$CMUX_CLAUDE_HOOKS_DISABLED" == "1" ]]; then
    exec "$REAL_CLAUDE" "$@"
fi

# Pass through subcommands that don't support hooks
case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

# Prevent nested session detection
unset CLAUDECODE

# Check if user already specified session flags
SKIP_SESSION_ID=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|--session-id|--session-id=*|--continue|-c)
            SKIP_SESSION_ID=true; break ;;
    esac
done

# Build hooks JSON — cmux-cli claude-hook sends socket commands to update sidebar.
# Uses 2>/dev/null || true so hook failures don't block Claude.
HOOKS_JSON='{"hooks":{"UserPromptSubmit":[{"matcher":"","hooks":[{"type":"command","command":"cmux-cli claude-hook active 2>/dev/null || true","timeout":5}]}],"Stop":[{"matcher":"","hooks":[{"type":"command","command":"cmux-cli claude-hook stop 2>/dev/null || true","timeout":10}]}],"Notification":[{"matcher":"permission_prompt","hooks":[{"type":"command","command":"cmux-cli claude-hook notification 2>/dev/null || true","timeout":10}]}]}}'

if [[ "$SKIP_SESSION_ID" == true ]]; then
    exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
else
    SESSION_ID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen | tr '[:upper:]' '[:lower:]')"
    exec "$REAL_CLAUDE" --session-id "$SESSION_ID" --settings "$HOOKS_JSON" "$@"
fi
